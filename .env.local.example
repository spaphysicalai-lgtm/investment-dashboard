# Replicate API 설정 (로컬 개발용)
# https://replicate.com/account/api-tokens 에서 API 토큰 발급

REPLICATE_API_TOKEN=your-replicate-api-token-here

# 텍스트 생성 모델 (Claude 4.5 Sonnet)
REPLICATE_TEXT_MODEL=anthropic/claude-4.5-sonnet

# 이미지 생성 모델 (Black Forest Labs Flux Schnell - 고속 생성 모델)
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell